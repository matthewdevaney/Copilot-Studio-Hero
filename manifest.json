{
  "manifest_version": 3,
  "name": "Copilot Studio Hero",
  "version": "0.2.2",
  "description": "A Chrome extension for Microsoft Copilot Studio",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Copilot Studio Hero"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
